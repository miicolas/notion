# Copier vers demo-local.env (non versionné recommandé) et compléter.
# Le script demo-presentation.sh charge automatiquement demo-local.env s'il existe.
#
# cp infrastructure/scripts/demo-local.env.example infrastructure/scripts/demo-local.env

# --- Base de données (migrations + API locale) ---
# Sur l’hôte : Postgres du devcontainer mappe 5433 -> 5432 (voir .devcontainer/docker-compose.yml)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/notion
# Depuis le service "app" du dev container (hôte db) :
# DATABASE_URL=postgresql://postgres:postgres@db:5432/notion

# DATABASE_URL=

# Backup (runBackup + POST /api/cron/backup) : bucket cible : si la ligne backup_config en base a
# s3_bucket vide, l’API utilise quand même BACKUP_S3_BUCKET depuis l’env (voir backup.ts).
# En local, il faut des credentials AWS avec s3:PutObject sur ce bucket.
# BACKUP_S3_BUCKET=
#
# Obligatoires pour deploy-aws.ts (Lambda, S3, CloudFormation) si pas de profil ~/.aws chargé par le SDK :
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   (optionnel, IAM temporaire)
# AWS_REGION=eu-west-3   (cohérent avec S3_REGION / ressources)

# --- API locale (obligatoire pour démarrer apps/api : voir apps/api/src/env.ts) ---
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3001
# MIGRATE_PASSWORD=
# S3_ASSETS_BUCKET=your-assets-bucket

# Port healthcheck (défaut 3001 si vous n'avez pas modifié apps/api/src/index.ts)
# API_PORT=3001

# --- Déploiement AWS (laisser vide pour sauter les étapes ou utiliser --dry-run) ---
# API_LAMBDA_NAME=staging-api-lambda
# LAMBDA_ENV_VARS='{"S3_ASSETS_BUCKET":"...","BACKUP_S3_BUCKET":"...",...}'

# VITE_API_URL=https://votre-api.example.com
# WEB_S3_BUCKET=
# WEB_CLOUDFRONT_ID=
# ADMIN_S3_BUCKET=
# ADMIN_CLOUDFRONT_ID=

# S3_ASSETS_BUCKET=   # même bucket que l'API pour deploy-assets (préfixe static/)
# STATIC_PREFIX=static

# Backup cron (deploy EventBridge + Lambda ; même secret que sur l'API en prod)
# BACKUP_ENVIRONMENT=staging
# API_PUBLIC_URL=https://api.staging.example.com
# CRON_SECRET=

# --- Option : preuve curl POST /api/cron/backup en local (nécessite CRON_SECRET sur l'API) ---
# DEMO_CRON_SECRET=...   # doit égaler CRON_SECRET côté process API testé

# Demander confirmation avant chaque déploiement AWS (1 = oui, défaut)
# REQUIRE_DEPLOY_CONFIRM=1

# API locale : background (défaut) ou manual (vous lancez l'API dans un autre terminal)
# DEMO_API_MODE=background
